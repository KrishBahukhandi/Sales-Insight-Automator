# ─────────────────────────────────────────────────────────────────────────────
# Sales Insight Automator — Environment Configuration (MERN Stack)
# Copy to .env and fill values before running docker-compose
# ─────────────────────────────────────────────────────────────────────────────

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Local (docker-compose) — constructed automatically; override only if needed
MONGO_URI=mongodb://admin:secret@mongo:27017/salesinsight?authSource=admin
MONGO_USER=admin
MONGO_PASSWORD=secret

# External MongoDB Atlas (use this for Render deployment)
# MONGO_URI=mongodb+srv://<user>:<password>@cluster0.bzeegta.mongodb.net/salesinsight?retryWrites=true&w=majority&appName=Cluster0

# ── AI Engine ────────────────────────────────────────────────────────────────
# Groq (Llama 3-70B) — https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Email Delivery ────────────────────────────────────────────────────────────
# Option A: SendGrid (recommended for production)
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Option B: SMTP (Gmail etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx

# Sender identity
FROM_EMAIL=noreply@rabbitt.ai
FROM_NAME=Rabbitt AI — Sales Insight

# ── API Security (optional) ───────────────────────────────────────────────────
# Set to enable X-API-Key header requirement on all /api/* endpoints
API_KEY=

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000
LOG_LEVEL=info

# ── Frontend ──────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000
